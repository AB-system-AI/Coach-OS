# =============================================================================
# CoachOS — Required environment variables
# Copy this file to `.env` for local development.
# On Vercel, set these in Project → Settings → Environment Variables.
# =============================================================================

# PostgreSQL connection string (required at runtime)
# Example: postgresql://user:password@localhost:5432/coachos?schema=public
# Use a managed provider in production (Neon, Supabase, Railway, etc.).
# For Vercel/serverless with PgBouncer, use the pooled URL here:
#   postgresql://user:pass@host/db?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Direct connection for Prisma migrations (optional; required if DATABASE_URL uses PgBouncer)
# Example: postgresql://user:password@host:5432/coachos?schema=public
DIRECT_URL=

# Secret used by Better Auth to sign sessions and tokens (required at runtime)
# Must be at least 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL where the app is served — used by Better Auth for callbacks
# Local: http://localhost:3000
# Production: https://your-domain.com
# On Vercel, falls back to VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL if unset.
BETTER_AUTH_URL=

# Public app URL exposed to the browser (recommended; should match BETTER_AUTH_URL)
# If unset, the browser auth client uses same-origin /api/auth.
NEXT_PUBLIC_APP_URL=

# Comma-separated extra origins allowed for Better Auth CSRF checks (optional).
# Use when serving the app on multiple domains (e.g. custom domain + vercel.app).
# www/non-www variants are added automatically for BETTER_AUTH_URL and NEXT_PUBLIC_APP_URL.
# BETTER_AUTH_TRUSTED_ORIGINS=

# Set to true to require email verification before sign-in (production launch).
REQUIRE_EMAIL_VERIFICATION=false

# =============================================================================
# Optional — OAuth
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Optional — Payments
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs for each plan (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# =============================================================================
# Optional — File uploads & media
# =============================================================================

UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# Optional — Email (Resend)
# =============================================================================

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@coachos.app
RESEND_FROM_NAME=CoachOS

# =============================================================================
# Optional — Rate limiting (Upstash Redis)
# If not set, falls back to in-memory rate limiting (not suitable for multi-instance production).
# Create a Redis database at https://console.upstash.com
# =============================================================================

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Optional — Error monitoring (Sentry)
# =============================================================================

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# Optional — AI
# =============================================================================

OPENAI_API_KEY=

# =============================================================================
# Optional — Security / Antivirus
# =============================================================================

# Webhook URL to send file metadata for virus scanning
VIRUS_SCAN_WEBHOOK_URL=

# =============================================================================
# Optional — Realtime (Pusher)
# =============================================================================

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# =============================================================================
# Optional — Branding
# =============================================================================

NEXT_PUBLIC_APP_NAME=CoachOS

# =============================================================================
# Optional — Operations
# =============================================================================

# Set to true during planned downtime (public marketing pages still work)
MAINTENANCE_MODE=false

# =============================================================================
# Optional — Web Push (VAPID)
# =============================================================================

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=noreply@coachos.app
