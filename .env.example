# =============================================================================
# CoachOS — Required environment variables
# Copy this file to `.env` for local development.
# On Vercel, set these in Project → Settings → Environment Variables.
# =============================================================================

# PostgreSQL connection string (required at runtime)
# Example: postgresql://user:password@localhost:5432/coachos?schema=public
# Use a managed provider in production (Neon, Supabase, Railway, etc.).
DATABASE_URL=

# Secret used by Better Auth to sign sessions and tokens (required at runtime)
# Must be at least 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL where the app is served — used by Better Auth for callbacks (required in production)
# Local: http://localhost:3000
# Production: https://your-domain.com
BETTER_AUTH_URL=

# Public app URL exposed to the browser (required for auth client and links)
# Should match BETTER_AUTH_URL in most deployments.
NEXT_PUBLIC_APP_URL=

# =============================================================================
# Optional — OAuth
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Optional — Payments
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# =============================================================================
# Optional — File uploads & media
# =============================================================================

UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# Optional — Email
# =============================================================================

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@coachos.app

# =============================================================================
# Optional — Realtime (Pusher)
# =============================================================================

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# =============================================================================
# Optional — Branding
# =============================================================================

NEXT_PUBLIC_APP_NAME=CoachOS
