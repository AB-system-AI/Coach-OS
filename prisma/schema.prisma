// CoachOS — Multi-Tenant SaaS Database Schema
// Every tenant-scoped table includes tenantId for isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  COACH
  ASSISTANT_COACH
  CLIENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MediaCategory {
  GENERAL
  IMAGE
  VIDEO
  DOCUMENT
  PDF
  EXERCISE_FILE
}

enum AIConversationType {
  COACH_ASSISTANT
  MEAL_SUGGESTION
  WORKOUT_SUGGESTION
  PROGRESS_SUMMARY
  CLIENT_INSIGHTS
}

enum WebhookEvent {
  BOOKING_CREATED
  BOOKING_CANCELLED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  CLIENT_CREATED
  CLIENT_UPDATED
  PROGRAM_ENROLLED
  REVIEW_CREATED
}

enum ApiKeyScope {
  READ
  WRITE
  FULL
}

enum DomainStatus {
  PENDING
  VERIFYING
  VERIFIED
  FAILED
}

enum BusinessType {
  FITNESS_COACH
  PERSONAL_TRAINER
  NUTRITION_COACH
  GYM
  FITNESS_ACADEMY
  FOOTBALL_COACH
  SWIMMING_COACH
  CROSSFIT_COACH
  YOGA_INSTRUCTOR
  PILATES_INSTRUCTOR
  BOXING_COACH
  MARTIAL_ARTS_COACH
  RUNNING_COACH
  CYCLING_COACH
  PHYSIOTHERAPIST
  REHABILITATION_CENTER
  SPORTS_CLINIC
}

enum TenantModuleKey {
  PROGRAMS
  NUTRITION
  RECOVERY
  MARKETPLACE
  COURSES
  BLOG
  SHOP
  BOOKINGS
  AI
  REPORTS
  CRM
  LOYALTY
  CHALLENGES
  COMMUNITY
  AUTOMATION
  MARKETING
  DIGITAL_PRODUCTS
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  ATTACHMENT
}

enum DigitalProductType {
  PDF_PROGRAM
  WORKOUT_PLAN
  MEAL_PLAN
  TEMPLATE
  EBOOK
  GUIDE
  CHALLENGE
}

enum ShopOrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum CrmLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum CrmActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  TASK
}

enum ChallengeType {
  THIRTY_DAY
  WEIGHT_LOSS
  MUSCLE_GAIN
  CUSTOM
}

enum AutomationTrigger {
  CLIENT_CREATED
  BOOKING_CREATED
  BOOKING_REMINDER
  PAYMENT_RECEIVED
  SUBSCRIPTION_RENEWAL
  RECOVERY_REMINDER
  APPOINTMENT_REMINDER
  BIRTHDAY
  COURSE_ENROLLED
  CHALLENGE_JOINED
}

enum AutomationAction {
  SEND_EMAIL
  SEND_NOTIFICATION
  SEND_WHATSAPP
  CREATE_TASK
  AWARD_POINTS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYMOB
  MANUAL
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  BOOKING
  PAYMENT
  MESSAGE
  PROGRAM
  SYSTEM
  REMINDER
  ANNOUNCEMENT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  WHATSAPP
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  BOOKING
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================================
// AUTH (Better Auth compatible)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(CLIENT)
  locale        String    @default("en")
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  memberships   TenantMember[]
  notifications Notification[]
  auditLogs     AuditLog[]
  sentMessages  ChatMessage[]  @relation("SentMessages")
  supportTickets SupportTicket[] @relation("TicketCreator")
  assignedTickets SupportTicket[] @relation("TicketAssignee")

  // Client-specific relations (scoped via tenant)
  clientProfile     ClientProfile?
  weightEntries     WeightEntry[]
  measurements      BodyMeasurement[]
  progressPhotos    ProgressPhoto[]
  programEnrollments ProgramEnrollment[]
  bookings          Booking[]
  payments          Payment[]
  reviews           Review[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Tenant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  status           TenantStatus     @default(TRIAL)
  plan             SubscriptionPlan @default(FREE)
  customDomain     String?          @unique
  domainVerified   Boolean          @default(false)
  storageUsedBytes BigInt           @default(0)
  storageLimitBytes BigInt          @default(5368709120) // 5GB default
  trialEndsAt      DateTime?
  businessType     BusinessType?
  onboardingCompleted Boolean      @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  theme            TenantTheme?
  settings         TenantSettings?
  members          TenantMember[]
  subscription     TenantSubscription?
  pages            CmsPage[]
  blogPosts        BlogPost[]
  blogCategories   BlogCategory[]
  programs         Program[]
  workoutPlans     WorkoutPlan[]
  mealPlans        MealPlan[]
  recipes          Recipe[]
  recoveryServices RecoveryService[]
  recoveryPackages RecoveryPackage[]
  timeSlots        TimeSlot[]
  bookings         Booking[]
  clients          ClientProfile[]
  payments         Payment[]
  invoices         Invoice[]
  coupons          Coupon[]
  media            Media[]
  exerciseVideos   ExerciseVideo[]
  notifications    Notification[]
  chatRooms        ChatRoom[]
  reviews          Review[]
  faqs             Faq[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]
  marketplaceProfile CoachMarketplaceProfile?
  certifications   CoachCertification[]
  galleryItems     CoachGalleryItem[]
  customDomains    CustomDomain[]
  announcements    TenantAnnouncement[]
  aiConversations  AIConversation[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  moduleConfigs    TenantModuleConfig[]
  courses          Course[]
  digitalProducts  DigitalProduct[]
  shopProducts     ShopProduct[]
  shopCategories   ShopCategory[]
  shopOrders       ShopOrder[]
  crmLeads         CrmLead[]
  crmPipelines     CrmPipeline[]
  loyaltyProgram   LoyaltyProgram?
  challenges       Challenge[]
  communityGroups  CommunityGroup[]
  automationRules  AutomationRule[]
  marketingCampaigns MarketingCampaign[]
  newsletterSubs   NewsletterSubscriber[]
  landingPages     LandingPage[]
  mediaFolders     MediaFolder[]

  @@index([slug])
  @@index([customDomain])
  @@index([status])
  @@map("tenants")
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(CLIENT)
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_members")
}

model TenantTheme {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String  @default("#6366f1")
  secondaryColor  String  @default("#8b5cf6")
  accentColor     String  @default("#06b6d4")
  backgroundColor String  @default("#ffffff")
  textColor       String  @default("#0f172a")
  fontFamily      String  @default("Inter")
  headingFont     String  @default("Inter")
  borderRadius    String  @default("0.625rem")
  heroImageUrl    String?
  heroTitle       String?
  heroSubtitle    String?
  heroCtaText     String?
  heroCtaLink     String?
  footerText      String?
  socialLinks     Json    @default("{}")
  whatsappNumber  String?
  customCss       String?

  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_themes")
}

model TenantSettings {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  businessName        String?
  businessEmail       String?
  businessPhone       String?
  businessAddress     String?
  currency            String  @default("USD")
  timezone            String  @default("UTC")
  locale              String  @default("en")
  stripeAccountId     String?
  paymobMerchantId    String?
  emailNotifications  Boolean @default(true)
  smsNotifications    Boolean @default(false)
  whatsappEnabled     Boolean @default(false)
  bookingLeadTime     Int     @default(24) // hours
  cancellationPolicy  String?
  privacyPolicy       String?
  termsOfService      String?
  seoTitle            String?
  seoDescription      String?
  seoKeywords         String?
  googleAnalyticsId   String?
  metaPixelId         String?
  // White-label email branding
  emailFromName       String?
  emailFromAddress    String?
  emailLogoUrl        String?
  emailPrimaryColor   String?
  emailFooterText     String?
  // Marketplace
  marketplaceEnabled  Boolean @default(false)
  // Social & location
  whatsappNumber      String?
  facebookUrl         String?
  instagramUrl        String?
  tiktokUrl           String?
  youtubeUrl          String?
  city                String?
  country             String?
  latitude            Float?
  longitude           Float?
  googleMapsUrl       String?
  // Marketing pixels
  tiktokPixelId       String?
  newsletterEnabled   Boolean @default(false)

  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
}

// ============================================================
// CMS & WEBSITE
// ============================================================

model CmsPage {
  id              String     @id @default(cuid())
  tenantId        String
  slug            String
  title           String
  content         Json       @default("{}")
  sections        Json       @default("[]")
  status          PageStatus @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("cms_pages")
}

model BlogCategory {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime   @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts     BlogPost[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_categories")
}

model BlogPost {
  id              String        @id @default(cuid())
  tenantId        String
  categoryId      String?
  title           String
  slug            String
  excerpt         String?
  content         String
  coverImageUrl   String?
  authorName      String?
  status          PageStatus    @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        BlogCategory? @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_posts")
}

model Faq {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("faqs")
}

// ============================================================
// CLIENTS
// ============================================================

model ClientProfile {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String    @unique
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  height        Float?    // cm
  goals         String?
  medicalNotes  String?
  emergencyContact String?
  isActive      Boolean   @default(true)
  joinedAt      DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("client_profiles")
}

// ============================================================
// PROGRAMS & WORKOUTS
// ============================================================

model Program {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  slug            String
  description     String?
  coverImageUrl   String?
  price           Decimal       @default(0) @db.Decimal(10, 2)
  currency        String        @default("USD")
  durationWeeks   Int?
  status          ProgramStatus @default(DRAFT)
  isPublic        Boolean       @default(false)
  features        String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workoutPlans    WorkoutPlan[]
  mealPlans       MealPlan[]
  enrollments     ProgramEnrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("programs")
}

model ProgramEnrollment {
  id          String    @id @default(cuid())
  programId   String
  userId      String
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  progress    Int       @default(0) // percentage
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([programId, userId])
  @@index([userId])
  @@map("program_enrollments")
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  tenantId    String
  programId   String?
  name        String
  description String?
  weekNumber  Int?
  dayNumber   Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program? @relation(fields: [programId], references: [id])
  exercises   WorkoutExercise[]

  @@index([tenantId])
  @@index([programId])
  @@map("workout_plans")
}

model WorkoutExercise {
  id            String  @id @default(cuid())
  workoutPlanId String
  name          String
  sets          Int?
  reps          String?
  weight        String?
  restSeconds   Int?
  notes         String?
  videoUrl      String?
  order         Int     @default(0)

  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([workoutPlanId])
  @@map("workout_exercises")
}

model ExerciseVideo {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  videoUrl    String
  thumbnailUrl String?
  category    String?
  muscleGroup String?
  equipment   String?
  duration    Int?     // seconds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("exercise_videos")
}

// ============================================================
// MEALS & RECIPES
// ============================================================

model MealPlan {
  id          String   @id @default(cuid())
  tenantId    String
  programId   String?
  name        String
  description String?
  dayNumber   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     Program? @relation(fields: [programId], references: [id])
  meals       Meal[]

  @@index([tenantId])
  @@index([programId])
  @@map("meal_plans")
}

model Meal {
  id          String  @id @default(cuid())
  mealPlanId  String
  name        String
  mealType    String  // breakfast, lunch, dinner, snack
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?
  order       Int     @default(0)

  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipes     MealRecipe[]

  @@index([mealPlanId])
  @@map("meals")
}

model Recipe {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  instructions String?
  prepTime     Int?     // minutes
  cookTime     Int?
  servings     Int?
  calories     Int?
  protein      Float?
  carbs        Float?
  fat          Float?
  imageUrl     String?
  ingredients  Json     @default("[]")
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mealRecipes  MealRecipe[]

  @@index([tenantId])
  @@map("recipes")
}

model MealRecipe {
  id       String @id @default(cuid())
  mealId   String
  recipeId String

  meal     Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([mealId, recipeId])
  @@map("meal_recipes")
}

// ============================================================
// RECOVERY & BOOKING
// ============================================================

model RecoveryService {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  duration    Int      // minutes
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  imageUrl    String?
  capacity    Int      @default(1)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  timeSlots   TimeSlot[]
  packageItems RecoveryPackageItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("recovery_services")
}

model RecoveryPackage {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  sessions    Int
  validityDays Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       RecoveryPackageItem[]

  @@index([tenantId])
  @@map("recovery_packages")
}

model RecoveryPackageItem {
  id        String @id @default(cuid())
  packageId String
  serviceId String
  quantity  Int    @default(1)

  package   RecoveryPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service   RecoveryService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("recovery_package_items")
}

model TimeSlot {
  id          String    @id @default(cuid())
  tenantId    String
  serviceId   String?
  dayOfWeek   DayOfWeek
  startTime   String    // "09:00"
  endTime     String    // "10:00"
  capacity    Int       @default(1)
  isActive    Boolean   @default(true)

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service     RecoveryService? @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@index([serviceId])
  @@map("time_slots")
}

model Booking {
  id          String        @id @default(cuid())
  tenantId    String
  userId      String
  serviceId   String
  date        DateTime
  startTime   String
  endTime     String
  status      BookingStatus @default(PENDING)
  notes       String?
  price       Decimal       @db.Decimal(10, 2)
  currency    String        @default("USD")
  paymentId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])
  service     RecoveryService @relation(fields: [serviceId], references: [id])
  payment     Payment?        @relation(fields: [paymentId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([date])
  @@map("bookings")
}

// ============================================================
// PAYMENTS & INVOICES
// ============================================================

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  userId            String
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("USD")
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider
  providerPaymentId String?
  description       String?
  metadata          Json            @default("{}")
  refundedAmount    Decimal?        @db.Decimal(10, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

