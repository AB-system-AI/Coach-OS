// ============================================================
// AUTH (Better Auth compatible)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(CLIENT)
  locale        String    @default("en")
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  memberships   TenantMember[]
  notifications Notification[]
  auditLogs     AuditLog[]
  sentMessages  ChatMessage[]  @relation("SentMessages")
  supportTickets SupportTicket[] @relation("TicketCreator")
  assignedTickets SupportTicket[] @relation("TicketAssignee")

  // Client-specific relations (scoped via tenant)
  clientProfile     ClientProfile?
  weightEntries     WeightEntry[]
  measurements      BodyMeasurement[]
  progressPhotos    ProgressPhoto[]
  programEnrollments ProgramEnrollment[]
  bookings          Booking[]
  payments          Payment[]
  reviews           Review[]
  staffProfile      TenantStaff?
  voiceNotes          VoiceNote[]
  attendanceChecked   AttendanceRecord[] @relation("AttendanceChecker")
  gamificationProfile GamificationProfile?
  userDevices         UserDevice[]
  loginHistory        LoginHistory[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Tenant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  status           TenantStatus     @default(TRIAL)
  plan             SubscriptionPlan @default(FREE)
  customDomain     String?          @unique
  domainVerified   Boolean          @default(false)
  storageUsedBytes BigInt           @default(0)
  storageLimitBytes BigInt          @default(5368709120) // 5GB default
  trialEndsAt      DateTime?
  businessType     BusinessType?
  productLine      ProductLine      @default(COACH_OS)
  onboardingCompleted Boolean      @default(false)
  parentTenantId   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  theme            TenantTheme?
  settings         TenantSettings?
  members          TenantMember[]
  subscription     TenantSubscription?
  pages            CmsPage[]
  blogPosts        BlogPost[]
  blogCategories   BlogCategory[]
  programs         Program[]
  workoutPlans     WorkoutPlan[]
  mealPlans        MealPlan[]
  recipes          Recipe[]
  recoveryServices RecoveryService[]
  recoveryPackages RecoveryPackage[]
  timeSlots        TimeSlot[]
  bookings         Booking[]
  clients          ClientProfile[]
  payments         Payment[]
  invoices         Invoice[]
  coupons          Coupon[]
  media            Media[]
  exerciseVideos   ExerciseVideo[]
  notifications    Notification[]
  chatRooms        ChatRoom[]
  reviews          Review[]
  faqs             Faq[]
  supportTickets   SupportTicket[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]
  marketplaceProfile CoachMarketplaceProfile?
  certifications   CoachCertification[]
  galleryItems     CoachGalleryItem[]
  customDomains    CustomDomain[]
  announcements    TenantAnnouncement[]
  aiConversations  AIConversation[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  moduleConfigs    TenantModuleConfig[]
  courses          Course[]
  digitalProducts  DigitalProduct[]
  shopProducts     ShopProduct[]
  shopCategories   ShopCategory[]
  shopOrders       ShopOrder[]
  crmLeads         CrmLead[]
  crmPipelines     CrmPipeline[]
  loyaltyProgram   LoyaltyProgram?
  challenges       Challenge[]
  communityGroups  CommunityGroup[]
  automationRules  AutomationRule[]
  marketingCampaigns MarketingCampaign[]
  newsletterSubs   NewsletterSubscriber[]
  landingPages     LandingPage[]
  mediaFolders     MediaFolder[]
  brands           Brand[]
  franchiseLocations FranchiseLocation[]
  staffMembers     TenantStaff[]
  wallet           FinancialWallet?
  expenses         Expense[]
  attendanceRecords AttendanceRecord[]
  calendarEvents   CalendarEvent[]
  dynamicForms     DynamicForm[]
  automationWorkflows AutomationWorkflow[]
  voiceNotes       VoiceNote[]
  integrations     TenantIntegration[]
  affiliates       AffiliateReferral[]
  membershipCards  MembershipCard[]
  posTransactions  PosTransaction[]
  payrollRecords   PayrollRecord[]
  inventoryItems   InventoryItem[]
  backupRecords    BackupRecord[]
  emailTemplates   EmailTemplate[]
  invoiceTemplates InvoiceTemplate[]
  themeTemplates   ThemeTemplate[]
  knowledgeArticles KnowledgeArticle[]
  offlineSyncQueue OfflineSyncQueue[]
  giftCards        GiftCard[]
  deepLinks        DeepLink[]
  notificationChannels TenantNotificationChannelConfig[]
  calendarSyncConnections CalendarSyncConnection[]
  gamificationBadges GamificationBadge[]
  gamificationAchievements GamificationAchievement[]
  gamificationProfiles GamificationProfile[]
  leaderboardEntries LeaderboardEntry[]
  parentTenant     Tenant?          @relation("FranchiseTree", fields: [parentTenantId], references: [id])
  childTenants     Tenant[]         @relation("FranchiseTree")

  @@index([productLine])
  @@index([parentTenantId])
  @@index([slug])
  @@index([customDomain])
  @@index([status])
  @@map("tenants")
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(CLIENT)
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_members")
}

model TenantTheme {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String  @default("#6366f1")
  secondaryColor  String  @default("#8b5cf6")
  accentColor     String  @default("#06b6d4")
  backgroundColor String  @default("#ffffff")
  textColor       String  @default("#0f172a")
  fontFamily      String  @default("Inter")
  headingFont     String  @default("Inter")
  borderRadius    String  @default("0.625rem")
  heroImageUrl    String?
  heroTitle       String?
  heroSubtitle    String?
  heroCtaText     String?
  heroCtaLink     String?
  footerText      String?
  socialLinks     Json    @default("{}")
  whatsappNumber  String?
  customCss       String?

  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_themes")
}

model TenantSettings {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  businessName        String?
  businessEmail       String?
  businessPhone       String?
  businessAddress     String?
  currency            String  @default("USD")
  timezone            String  @default("UTC")
  locale              String  @default("en")
  stripeAccountId     String?
  paymobMerchantId    String?
  emailNotifications  Boolean @default(true)
  smsNotifications    Boolean @default(false)
  whatsappEnabled     Boolean @default(false)
  bookingLeadTime     Int     @default(24) // hours
  cancellationPolicy  String?
  privacyPolicy       String?
  termsOfService      String?
  seoTitle            String?
  seoDescription      String?
  seoKeywords         String?
  googleAnalyticsId   String?
  metaPixelId         String?
  // White-label email branding
  emailFromName       String?
  emailFromAddress    String?
  emailLogoUrl        String?
  emailPrimaryColor   String?
  emailFooterText     String?
  // Marketplace
  marketplaceEnabled  Boolean @default(false)
  // Social & location
  whatsappNumber      String?
  facebookUrl         String?
  instagramUrl        String?
  tiktokUrl           String?
  youtubeUrl          String?
  city                String?
  country             String?
  latitude            Float?
  longitude           Float?
  googleMapsUrl       String?
  // Marketing pixels
  tiktokPixelId       String?
  newsletterEnabled   Boolean @default(false)

  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
}

// ============================================================
// CMS & WEBSITE
// ============================================================

model CmsPage {
  id              String     @id @default(cuid())
  tenantId        String
  slug            String
  title           String
  content         Json       @default("{}")
  sections        Json       @default("[]")
  status          PageStatus @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("cms_pages")
}

model BlogCategory {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime   @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts     BlogPost[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_categories")
}

model BlogPost {
  id              String        @id @default(cuid())
  tenantId        String
  categoryId      String?
  title           String
  slug            String
  excerpt         String?
  content         String
  coverImageUrl   String?
  authorName      String?
  status          PageStatus    @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        BlogCategory? @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_posts")
}

model Faq {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("faqs")
}

// ============================================================
// CLIENTS
// ============================================================

model ClientProfile {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String    @unique
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  height        Float?    // cm
  goals         String?
  goalType      ClientGoalType?
  medicalNotes  String?
  emergencyContact String?
  subscriptionStatus ClientSubscriptionStatus @default(ACTIVE)
  subscriptionStartDate DateTime?
  subscriptionEndDate DateTime?
  isActive      Boolean   @default(true)
  joinedAt      DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceRecords AttendanceRecord[]
  membershipCards   MembershipCard[]
  notes         ClientNote[]
  files         ClientFile[]
  activities    ClientActivity[]
  weeklyCheckIns WeeklyCheckIn[]

  @@index([tenantId])
  @@map("client_profiles")
}

model ClientNote {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@map("client_notes")
}

model ClientFile {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  name      String
  url       String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())

  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@map("client_files")
}

model ClientActivity {
  id          String             @id @default(cuid())
  tenantId    String
  clientId    String
  type        ClientActivityType
  title       String
  description String?
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now())

  client      ClientProfile      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([createdAt])
  @@map("client_activities")
}

model WeeklyCheckIn {
  id              String              @id @default(cuid())
  tenantId        String
  clientId        String
  userId          String
  weekStartDate   DateTime
  weight          Float?
  bodyFatPercent  Float?
  adherenceScore  Int?
  programRating   Int?
  notes           String?
  coachReply      String?
  coachRepliedAt  DateTime?
  photoUrls       String[]            @default([])
  status          WeeklyCheckInStatus @default(PENDING)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  client          ClientProfile       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([weekStartDate])
  @@map("weekly_check_ins")
}

// ============================================================
// PROGRAMS & WORKOUTS
// ============================================================

model Program {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  slug            String
  description     String?
  coverImageUrl   String?
  price           Decimal       @default(0) @db.Decimal(10, 2)
  currency        String        @default("USD")
  durationWeeks   Int?
  status          ProgramStatus @default(DRAFT)
  isPublic        Boolean       @default(false)
  isTemplate      Boolean       @default(false)
  features        String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workoutPlans    WorkoutPlan[]
  mealPlans       MealPlan[]
  enrollments     ProgramEnrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("programs")
}

model ProgramEnrollment {
  id          String    @id @default(cuid())
  programId   String
  userId      String
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  progress    Int       @default(0) // percentage
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

