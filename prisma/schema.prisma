  name        String
  description String?
  iconUrl     String?
  xpRequired  Int      @default(0)
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userBadges  UserBadge[]

  @@index([tenantId])
  @@map("gamification_badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  profileId String
  badgeId   String
  earnedAt  DateTime @default(now())

  profile   GamificationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badge     GamificationBadge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([profileId, badgeId])
  @@map("user_badges")
}

model GamificationAchievement {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  xpReward    Int      @default(0)
  criteria    Json     @default("{}")
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userAchievements UserAchievement[]

  @@index([tenantId])
  @@map("gamification_achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  profileId     String
  achievementId String
  earnedAt      DateTime @default(now())

  profile       GamificationProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  achievement   GamificationAchievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([profileId, achievementId])
  @@map("user_achievements")
}

model LeaderboardEntry {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  period    String   @default("all_time")
  score     Int      @default(0)
  rank      Int?
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, period])
  @@index([tenantId, period, score])
  @@map("leaderboard_entries")
}

// ============================================================
// AFFILIATE & GIFT CARDS
// ============================================================

model AffiliateReferral {
  id            String          @id @default(cuid())
  tenantId      String
  affiliateCode String
  referrerName  String?
  referrerEmail String?
  status        AffiliateStatus @default(PENDING)
  commissionRate Decimal        @default(0) @db.Decimal(5, 2)
  totalEarnings Decimal         @default(0) @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, affiliateCode])
  @@index([tenantId])
  @@map("affiliate_referrals")
}

model GiftCard {
  id          String    @id @default(cuid())
  tenantId    String
  code        String
  amount      Decimal   @db.Decimal(10, 2)
  balance     Decimal   @db.Decimal(10, 2)
  currency    String    @default("USD")
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("gift_cards")
}

// ============================================================
// MEMBERSHIP CARDS, POS, INVENTORY, PAYROLL
// ============================================================

model MembershipCard {
  id          String             @id @default(cuid())
  tenantId    String
  clientId    String?
  cardNumber  String
  cardType    MembershipCardType @default(QR)
  qrPayload   String?
  barcodePayload String?
  nfcPayload  String?
  isActive    Boolean            @default(true)
  issuedAt    DateTime           @default(now())
  expiresAt   DateTime?

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      ClientProfile?     @relation(fields: [clientId], references: [id])

  @@unique([tenantId, cardNumber])
  @@index([tenantId])
  @@map("membership_cards")
}

model PosTransaction {
  id            String           @id @default(cuid())
  tenantId      String
  total         Decimal          @db.Decimal(12, 2)
  currency      String           @default("USD")
  paymentMethod PosPaymentMethod
  cashierName   String?
  metadata      Json             @default("{}")
  createdAt     DateTime         @default(now())

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         PosTransactionItem[]

  @@index([tenantId])
  @@index([createdAt])
  @@map("pos_transactions")
}

model PosTransactionItem {
  id            String   @id @default(cuid())
  transactionId String
  productName   String
  quantity      Int      @default(1)
  unitPrice     Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)

  transaction   PosTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("pos_transaction_items")
}

model InventoryItem {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String?
  name        String
  category    String?
  quantity    Int      @default(0)
  minStock    Int      @default(0)
  unitPrice   Decimal? @db.Decimal(10, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("inventory_items")
}

model PayrollRecord {
  id          String   @id @default(cuid())
  tenantId    String
  staffName   String
  periodStart DateTime
  periodEnd   DateTime
  baseSalary  Decimal  @db.Decimal(12, 2)
  commission  Decimal  @default(0) @db.Decimal(12, 2)
  deductions  Decimal  @default(0) @db.Decimal(12, 2)
  netPay      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  status      String   @default("pending")
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("payroll_records")
}

// ============================================================
// BUILDERS: EMAIL, INVOICE, THEME
// ============================================================

model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  subject     String
  htmlContent String
  jsonDesign  Json     @default("{}")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("email_templates")
}

model InvoiceTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  jsonDesign  Json     @default("{}")
  logoUrl     String?
  showQr      Boolean  @default(true)
  taxRate     Decimal? @db.Decimal(5, 2)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("invoice_templates")
}

model ThemeTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  jsonDesign  Json     @default("{}")
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("theme_templates")
}

// ============================================================
// BACKUP, HELP CENTER, OFFLINE SYNC, DEEP LINKS
// ============================================================

model BackupRecord {
  id          String       @id @default(cuid())
  tenantId    String
  type        BackupType   @default(FULL)
  status      BackupStatus @default(PENDING)
  fileUrl     String?
  fileSize    Int?
  metadata    Json         @default("{}")
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("backup_records")
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  slug        String
  content     String
  category    String?
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("knowledge_articles")
}

model OfflineSyncQueue {
  id         String         @id @default(cuid())
  tenantId   String
  userId     String
  entityType SyncEntityType
  entityId   String?
  payload    Json           @default("{}")
  status     SyncStatus     @default(PENDING)
  clientId   String?
  createdAt  DateTime       @default(now())
  syncedAt   DateTime?

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([status])
  @@map("offline_sync_queue")
}

model DeepLink {
  id         String       @id @default(cuid())
  tenantId   String
  code       String       @unique
  type       DeepLinkType
  targetId   String?
  metadata   Json         @default("{}")
  clickCount Int          @default(0)
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("deep_links")
}

model TenantNotificationChannelConfig {
  id        String   @id @default(cuid())
  tenantId  String
  channel   String
  isEnabled Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel])
  @@index([tenantId])
  @@map("tenant_notification_channels")
}

model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String?
  deviceName  String?
  deviceType  String?
  fingerprint String?
  isTrusted   Boolean  @default(false)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_devices")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  ipAddress String?
  userAgent String?
  location  String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

model ApiRequestLog {
  id         String   @id @default(cuid())
  tenantId   String?
  apiKeyId   String?
  method     String
  path       String
  statusCode Int
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@map("api_request_logs")
}

// ============================================================
// PLATFORM HEALTH & ENTERPRISE METRICS
// ============================================================

model SystemHealthSnapshot {
  id          String   @id @default(cuid())
  cpuPercent  Float?
  memoryPercent Float?
  storagePercent Float?
  activeTenants Int?
  metadata    Json     @default("{}")
  capturedAt  DateTime @default(now())

  @@index([capturedAt])
  @@map("system_health_snapshots")
}

model CronJobLog {
  id        String   @id @default(cuid())
  jobName   String
  status    String
  durationMs Int?
  error     String?
  ranAt     DateTime @default(now())

  @@index([jobName])
  @@index([ranAt])
  @@map("cron_job_logs")
}

model QueueMetric {
  id          String   @id @default(cuid())
  queueName   String
  pending     Int      @default(0)
  processing  Int      @default(0)
  failed      Int      @default(0)
  capturedAt  DateTime @default(now())

  @@index([queueName])
  @@index([capturedAt])
  @@map("queue_metrics")
}
